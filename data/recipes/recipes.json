  },
  {
    "id": "recipe-spam-filter",
    "name": "Spam Signal Suppressor",
    "description": "When a signal is classified as noise/spam, log it and skip further processing.",
    "enabled": true,
    "trigger": {
      "kind": "processing_complete",
      "conditions": {
        "result.is_noise": true
      }
    },
    "steps": [
      {
        "id": "s1",
        "kind": "log_note",
        "params": {
          "message": "Noise signal suppressed: {{trigger.signal.id}}"
        }
      }
    ],
    "risk_level": "low",
    "approval_required": false,
    "run_count": 2,
