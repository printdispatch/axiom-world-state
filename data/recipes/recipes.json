        }
      },
      {
        "id": "s2",
        "kind": "flag_for_review",
        "params": {
          "reason": "Invoice overdue: {{trigger.title}}"
        }
      }
    ],
    "risk_level": "medium",
    "approval_required": false,
    "run_count": 0,
