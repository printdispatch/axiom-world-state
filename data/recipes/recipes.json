  },
  {
    "id": "recipe-new-client-workspace",
    "name": "New Client Workspace Creator",
    "description": "When a new organization entity is created from a client email, automatically create a workspace for them.",
    "enabled": true,
    "trigger": {
      "kind": "entity_created",
      "conditions": {
        "domain": "organization"
      }
    },
    "steps": [
      {
        "id": "s1",
        "kind": "create_workspace",
        "params": {
          "name": "{{trigger.canonical_name}} — New Project",
          "client_name": "{{trigger.canonical_name}}",
          "status": "active"
        }
      },
      {
        "id": "s2",
        "kind": "log_note",
        "params": {
          "message": "Workspace created for new client: {{trigger.canonical_name}}"
        }
      }
    ],
    "risk_level": "low",
    "approval_required": false,
    "run_count": 0,
    "created_at": "2026-03-13T10:00:00Z",
    "updated_at": "2026-03-13T10:00:00Z"
  },
  {
    "id": "recipe-contradiction-escalate",
    "name": "Contradiction Escalation",
    "description": "When a contradiction is detected, immediately escalate to review queue with high severity.",
    "enabled": true,
    "trigger": {
      "kind": "contradiction_detected",
      "conditions": {}
    },
    "steps": [
      {
        "id": "s1",
        "kind": "flag_for_review",
        "params": {
          "reason": "Contradiction detected: {{trigger.description}}",
          "severity": "high"
        }
      },
      {
        "id": "s2",
        "kind": "log_note",
        "params": {
          "message": "Contradiction escalated for entities: {{trigger.entities}}"
        }
      }
    ],
    "risk_level": "high",
    "approval_required": true,
    "run_count": 0,
    "created_at": "2026-03-13T10:00:00Z",
    "updated_at": "2026-03-13T10:00:00Z"
  },
