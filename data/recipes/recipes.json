[
  {
    "id": "recipe-invoice-alert",
    "name": "Invoice Overdue Alert",
    "description": "When an invoice obligation becomes overdue, flag it for review and log a note.",
    "enabled": true,
    "trigger": {
      "kind": "obligation_overdue",
      "conditions": {}
    },
    "steps": [
      {
        "id": "s1",
        "kind": "log_note",
