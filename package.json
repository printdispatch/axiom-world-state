{
  "name": "axiom-world-state",
  "version": "0.1.0",
  "description": "A persistent, provenance-first world-state substrate for LLM agents.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration",
    "lint": "eslint src schema --ext .ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "ai-agent",
    "world-state",
    "provenance",
    "llm",
    "axiom",
    "persistent-memory"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/uuid": "^11.0.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "openai": "^6.27.0",
    "uuid": "^13.0.0"
  }
}